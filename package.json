{
  "name": "awslam",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "infra",
    "backend",
    "admin",
    "renderer",
    "tools/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "setup": "tsx scripts/setup.ts",
    "setup-config": "tsx scripts/setup-config.ts",
    "manage-domains": "tsx scripts/manage-domains.ts",
    "post-deploy": "npx tsx scripts/post-deploy.ts",
    "post-deploy-staging": "npx tsx scripts/post-deploy-staging.ts",
    "migrate-commerce-private-table": "npx tsx scripts/migrate-commerce-private-table.ts"
  },
  "dependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@aws-sdk/client-acm": "^3.1045.0",
    "@aws-sdk/client-cloudformation": "^3.1045.0",
    "@aws-sdk/client-secrets-manager": "^3.1045.0",
    "@aws-sdk/client-ssm": "^3.1045.0",
    "@aws-sdk/client-sts": "^3.1045.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.40",
    "prompts": "^2.4.2",
    "tsx": "^4.7.1"
  }
